{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "transport-paca",
  "version": "0.1.1",
  "identifier": "com.alecl.transport-paca",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Transport PACA",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri://localhost http://tauri.localhost; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline' https://rsms.me; font-src 'self' https://rsms.me data:; img-src 'self' data: blob:; connect-src 'self' http://127.0.0.1:19191 http://localhost:19191 tauri://localhost ipc:; frame-ancestors 'none'; base-uri 'self'; form-action 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://pub-b668794d0adc4056bbcaec6250de2a6b.r2.dev/latest.json"
      ],
      "pubkey": "RWRuZGFGY1IwSWRETzJ6a1FHaVRscTE3em01UisybzRKK05WTWVzVEgwUWRybFBiNk1vd05udQ=="
    }
  }
}
