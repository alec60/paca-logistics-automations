{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "transport-paca",
  "version": "0.1.0",
  "identifier": "com.alecl.transport-paca",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Transport PACA",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com"
      ],
      "pubkey": "RWRuZGFGY1IwSWRETzJ6a1FHaVRscTE3em01UisybzRKK05WTWVzVEgwUWRybFBiNk1vd05udQ=="
    }
  }
}

